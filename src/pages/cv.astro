---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify leading-8">
    Yuxi Qian is an undergraduate student in the School of Physical Sciences at the University of Science and Technology of
    China, minoring in Computer Science and Technology. Yuxi will join the School of Information Science and Technology at
    USTC as a Ph.D. student in 2026.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Ph.D. Student, School of Information Science and Technology"
      subtitle="2026 to present, University of Science and Technology of China"
    />
    <TimeLineElement
      title="B.S. Student, School of Physical Sciences"
      subtitle="2022 to 2026, University of Science and Technology of China"
    >
      Minor in Computer Science and Technology.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Contact</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Email: <a class="link" href="mailto:qianyx20040130@mail.ustc.edu.cn">qianyx20040130@mail.ustc.edu.cn</a></li>
    <li>Phone: <a class="link" href="tel:+8613114051133">+86 13114051133</a></li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-2 columns-1 mx-6">
    <li>Physics</li>
    <li>Computer Science and Technology</li>
  </ul>
</BaseLayout>
