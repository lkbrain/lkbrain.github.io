---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="Research Projects in AI for EDA"
    img="/post_img.webp"
    desc="This section will collect my research projects, code, and notes related to AI-assisted electronic design automation."
    url="https://github.com/lkbrain"
    badge="GitHub"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="MIRALab Research Work"
    img="/post_img.webp"
    desc="I am building my research experience at MIRALab, USTC. More project details will be added as they become ready to share."
    url="/services"
    target="_self"
  />
</BaseLayout>
