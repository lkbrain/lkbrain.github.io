---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hello, I am</div>
    <div class="text-5xl font-bold">Yuxi Qian</div>
    <div class="py-2 mt-4">
      <p class="text-lg leading-8">
        I am a 2026 Ph.D. student at the University of Science and Technology of China (USTC) and a member of MIRA Lab.
        My research field is <b>AI4EDA</b>, with interests focused on macro placement, global placement, and 3D chip design.
      </p>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Ph.D. Student"
      subtitle="2026 to present, University of Science and Technology of China"
    >
      MIRA Lab. Research interests include AI4EDA, macro placement, global placement, and 3D chip design.
    </TimeLineElement>
    <TimeLineElement
      title="B.S. Student"
      subtitle="2022 to 2026, University of Science and Technology of China"
    >
      Minor in Computer Science and Technology.
    </TimeLineElement>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Awards</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>National Natural Science Foundation of China Young Student Basic Research Program for Undergraduates</li>
    <li>Zhao Zhongyao Scholarship</li>
    <li>National Scholarship</li>
    <li>University of Science and Technology of China Honorary Distinction</li>
    <li>Outstanding Graduate of the University of Science and Technology of China</li>
    <li>Gold Award, University of Science and Technology of China Outstanding Student Scholarship</li>
    <li>Silver Award, University of Science and Technology of China Outstanding Student Scholarship</li>
  </ul>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Skills</div>
  </div>

  <ul class="list-disc md:columns-2 columns-1 mx-6 mb-10">
    <li>AI4EDA</li>
    <li>Macro Placement</li>
    <li>Global Placement</li>
    <li>3D Chip Design</li>
    <li>Physics</li>
    <li>Computer Science and Technology</li>
  </ul>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Contact</div>
  </div>

  <div class="overflow-x-auto">
    <table class="table">
      <tbody>
        <tr>
          <th>Email</th>
          <td><a class="link" href="mailto:qianyx20040130@mail.ustc.edu.cn">qianyx20040130@mail.ustc.edu.cn</a></td>
        </tr>
        <tr>
          <th>Phone</th>
          <td><a class="link" href="tel:+8613114051133">+86 13114051133</a></td>
        </tr>
        <tr>
          <th>Affiliation</th>
          <td>University of Science and Technology of China</td>
        </tr>
      </tbody>
    </table>
  </div>
</BaseLayout>
