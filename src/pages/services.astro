---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Research" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Research</div>
  </div>

  <div class="mb-8 text-lg leading-8">
    My current research direction is AI for EDA at MIRALab, USTC. I focus on how AI methods can support electronic design
    automation workflows and help solve optimization, prediction, and design-space exploration problems in chip design.
  </div>

  <HorizontalCard
    title="AI for Electronic Design Automation"
    img="/post_img.webp"
    desc="Learning-based methods for improving EDA workflows, with emphasis on intelligent optimization and design-flow assistance."
    badge="AI for EDA"
    url="#"
    target="_self"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Machine Learning for Physical Design"
    img="/post_img.webp"
    desc="Exploring how data-driven models can support placement, routing, timing, and other physical-design related tasks."
    url="#"
    target="_self"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Interdisciplinary Background"
    img="/post_img.webp"
    desc="Combining physics training with computer science to study computational and optimization problems in EDA."
    url="/cv"
    target="_self"
  />
</BaseLayout>
