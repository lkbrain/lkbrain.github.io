---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Research" sideBarActiveItemID="services">
  <div class="mb-8">
    <div class="text-3xl w-full font-bold mb-3">Research</div>
    <p class="text-lg leading-8">
      My current research focuses on AI4EDA, especially placement optimization for advanced chip design.
    </p>
  </div>

  <div class="grid gap-4">
    <a
      href="/research/fireplace-thermal-aware-placement/"
      class="block rounded-lg border border-base-300 bg-base-100 p-5 transition hover:-translate-y-0.5 hover:border-base-content/30 hover:shadow-md"
    >
      <div class="badge badge-secondary mb-3">Research Blog</div>
      <h2 class="text-2xl font-bold leading-tight">
        FirePlace: Thermal-Aware Placement for 3D ICs
      </h2>
      <p class="mt-2 mb-4 opacity-75">
        Notes on my TCAD work on thermal-aware macro and standard-cell placement for F2F-bonded 3D ICs.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="rounded border border-base-300 px-3 py-1 text-sm">AI4EDA</span>
        <span class="rounded border border-base-300 px-3 py-1 text-sm">3D IC</span>
        <span class="rounded border border-base-300 px-3 py-1 text-sm">Macro Placement</span>
        <span class="rounded border border-base-300 px-3 py-1 text-sm">Global Placement</span>
        <span class="rounded border border-base-300 px-3 py-1 text-sm">Thermal-Aware Design</span>
        <span class="rounded border border-base-300 px-3 py-1 text-sm">GPU Acceleration</span>
      </div>
    </a>
  </div>
</BaseLayout>
